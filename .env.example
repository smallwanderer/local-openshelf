# =========================
# Django
# =========================
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
DJANGO_TIME_ZONE=Asia/Seoul
DJANGO_LANGUAGE_CODE=ko-kr
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com


# =========================
# Database (PostgreSQL)
# =========================
# Inside Docker Compose, keep POSTGRES_HOST=db and POSTGRES_PORT=5432.
# For host-side pytest runs against the mapped database port, conftest.py
# defaults to localhost:5433 unless you override it explicitly.
POSTGRES_DB=filehub
POSTGRES_USER=filehub
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432


# =========================
# Optional app settings
# =========================
MEDIA_ROOT=/data/uploads
MEDIA_URL=/media/
LOG_LEVEL=INFO
DOCUMENT_AI_RECOVERY_INTERVAL_SECONDS=300
DOCUMENT_AI_RECOVERY_STALE_MINUTES=30
DOCUMENT_AI_RECOVERY_PARSE_BATCH_SIZE=50
DOCUMENT_AI_RECOVERY_EMBED_BATCH_SIZE=200
DOCUMENT_AI_MAX_RECOVERY_ATTEMPTS=5


# =========================
# LLM
# =========================
HF_TOKEN=huggingface_token
TEXT2SQL_LLM_URL=http://llm-parser:8080
TEXT2SQL_WORKER_CONCURRENCY=1
TEXT2SQL_SEMAPHORE_COUNT=1
TEXT2SQL_SEMAPHORE_NAMESPACE=llm_text2sql_v2
TEXT2SQL_SEMAPHORE_TIMEOUT=5
TEXT2SQL_REQUEST_TIMEOUT=300
TEXT2SQL_MAX_TOKENS=128
