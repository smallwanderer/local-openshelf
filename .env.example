# =========================
# Django
# =========================
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=0

# 실제 도메인이 결정되면 localhost 자리에 도메인을 추가해야 합니다.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost, http://127.0.0.1, http://localhost:8888, http://127.0.0.1:8888
DJANGO_TIME_ZONE=Asia/Seoul
DJANGO_LANGUAGE_CODE=ko-kr


# =============================================================================
# Email
# =============================================================================
REQUIRE_EMAIL_VERIFICATION=0
# 개발: console 백엔드 (이메일을 stdout 으로 출력)
# 운영: smtp 백엔드로 변경
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com

# SMTP 사용 시 아래 항목 설정 (console 백엔드일 때는 무시됨)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_HOST_USER=user@example.com
# EMAIL_HOST_PASSWORD=change-me


# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_DB=openshelf
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432


# =============================================================================
# Redis / Celery Broker
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
#CELERY_RESULT_BACKEND=django-celery-results 를 사용하므로 설정 불필요

# =============================================================================
# Media / Static
# =============================================================================
MEDIA_ROOT=/data/uploads
MEDIA_URL=/media/

# =============================================================================
# Logging
# =============================================================================
# 컨테이너 기준 로그 저장 경로입니다. docker-compose에서 ./data/logs 로 마운트됩니다.
LOG_DIR=/data/logs

# 운영 문제 확인용 전체 로그 레벨입니다. WARNING이면 경고/오류만 operations.log에 저장합니다.
OPERATION_LOG_LEVEL=WARNING

# AI 파이프라인 흐름 확인용 로그 레벨입니다. INFO면 파싱/청킹/임베딩 진행 로그를 저장합니다.
DOCUMENT_AI_LOG_LEVEL=INFO


# =============================================================================
# Document AI — Parser & Chunker
# =============================================================================
# 임베딩 모델 이름 (HuggingFace hub ID)
EMBEDDING_MODEL=BAAI/bge-m3

# 임베딩 백엔드 식별자 (ChunkEmbedding.model_version 에 저장됨)
EMBEDDING_BACKEND=bgem3_hybrid

# 청크당 최대 토큰 수
CHUNK_MAX_TOKENS=1024

# 임베딩 시 컨텍스트 추가로 인한 토큰 여유분
EMBEDDING_TOKEN_HEADROOM=256

# 임베딩 최대 토큰 (미설정 시 CHUNK_MAX_TOKENS + EMBEDDING_TOKEN_HEADROOM)
# EMBEDDING_MAX_TOKENS=1280

# 검색 query 임베딩 최대 토큰 (미설정 시 문서 임베딩 최대 토큰 정책 사용)
# QUERY_EMBEDDING_MAX_TOKENS=256


# =============================================================================
# Document AI — Retriever (Hybrid Search)
# =============================================================================
# dense retriever 거리 전략: inner_product, cosine, l2
EMBEDDING_DISTANCE_STRATEGY=inner_product

# 문서 점수 pooling 방식: normalized_logsumexp 권장, max 선택 가능
EMBEDDING_DOC_POOLING_METHOD=normalized_logsumexp

# 하이브리드 스코어 가중치 (합계 = 1.0 권장)
EMBEDDING_HYBRID_DENSE_WEIGHT=0.7
EMBEDDING_HYBRID_SPARSE_WEIGHT=0.3

# dense 1차 후보 = top_k × candidate_multiplier
EMBEDDING_HYBRID_CANDIDATE_MULTIPLIER=12

# 문서당 dense 후보 최대 허용 개수
EMBEDDING_PER_NODE_CANDIDATE_CAP=4

# 쿼리 sparse 벡터에서 상위 N개 토큰만 사용
EMBEDDING_QUERY_SPARSE_TOP_N=32

# 최종 결과에 포함할 evidence 청크 수
EMBEDDING_EVIDENCE_TOP_K=3

# 문서 점수 pooling 에 사용할 청크 수
EMBEDDING_DOC_POOL_TOP_K=5

# normalized_logsumexp pooling 온도 (클수록 max-pooling 에 가까워짐)
EMBEDDING_DOC_POOL_TAU=10.0

# 문서 길이 패널티 강도 (0 = 패널티 없음)
EMBEDDING_DOC_LENGTH_PENALTY_ALPHA=0.0

# evidence 에 인접 청크 몇 개를 포함할지 (0 = 해당 청크만)
EMBEDDING_EVIDENCE_CONTEXT_WINDOW=1

# 검색/RAG contextual compression: 검색된 chunk 내부에서 질문 관련 segment만 추출
CONTEXTUAL_COMPRESSION_ENABLED=1
CONTEXTUAL_COMPRESSION_WINDOW_SIZE=2
CONTEXTUAL_COMPRESSION_MAX_SEGMENTS_PER_CHUNK=16
CONTEXTUAL_COMPRESSION_TOP_SEGMENTS=3
CONTEXTUAL_COMPRESSION_MAX_CHARS=700
CONTEXTUAL_COMPRESSION_MIN_SCORE=0.1
CONTEXTUAL_COMPRESSION_DENSE_WEIGHT=0.4
CONTEXTUAL_COMPRESSION_SPARSE_WEIGHT=0.6


# =============================================================================
# Document AI — Pipeline Recovery (Celery Beat)
# =============================================================================
# 복구 태스크 실행 주기 (초)
DOCUMENT_AI_RECOVERY_INTERVAL_SECONDS=300

# 이 시간(분) 이상 stale 상태인 항목을 복구 대상으로 간주
DOCUMENT_AI_RECOVERY_STALE_MINUTES=30

# 복구 태스크당 파싱 재큐잉 최대 건수
DOCUMENT_AI_RECOVERY_PARSE_BATCH_SIZE=50

# 복구 태스크당 임베딩 재큐잉 최대 청크 수
DOCUMENT_AI_RECOVERY_EMBED_BATCH_SIZE=200

# 파일/청크당 복구 재시도 최대 횟수 (초과 시 영구 제외)
DOCUMENT_AI_MAX_RECOVERY_ATTEMPTS=5

# 파싱/임베딩 Celery 워커 동시 실행 수
DOCUMENT_AI_WORKER_CONCURRENCY=1

# 검색 Celery 워커 동시 실행 수
SEARCH_WORKER_CONCURRENCY=1

# 사용자 질문 파싱 Celery 워커 동시 실행 수
QUERY_WORKER_CONCURRENCY=1


# =============================================================================
# LLM (Text2SQL — llama.cpp / llm-parser 서비스)
# =============================================================================
# HuggingFace 토큰 (Gemma 모델 다운로드에 필요)
HF_TOKEN=hf_your_token_here

# llm-parser 서비스 엔드포인트
TEXT2SQL_LLM_URL=http://llm-parser:8080

# Text2SQL 워커 동시 실행 수 (GPU 메모리에 맞게 조정)
TEXT2SQL_WORKER_CONCURRENCY=1

# Redis Semaphore 설정 (동시 LLM 요청 수 제한)
TEXT2SQL_SEMAPHORE_COUNT=1
TEXT2SQL_SEMAPHORE_NAMESPACE=llm_text2sql_v2
TEXT2SQL_SEMAPHORE_TIMEOUT=5

# LLM 요청 타임아웃 (초)
TEXT2SQL_REQUEST_TIMEOUT=300

# LLM 응답 최대 토큰 수
TEXT2SQL_MAX_TOKENS=128

# QueryDSL parser는 실험 기능입니다.
# 기본 검색/RAG 경로는 query_frontend에서 원 질의를 semantic query로 그대로 전달합니다.
# 향후 opt-in 평가 시 QUERY_FRONTEND_MODE=experimental_querydsl 경로에 연결합니다.
QUERY_FRONTEND_MODE=passthrough
QUERY_PIPELINE_ENABLED=1
QUERY_PIPELINE_MAX_VALIDATION_PASSES=2
QUERY_LLM_ENABLED=1
QUERY_LLM_URL=http://llm-parser:8080
QUERY_LLM_MODEL=google/gemma-4-E4B-it
QUERY_MAX_TOKENS=1024
QUERY_REQUEST_TIMEOUT=300
QUERY_TEMPERATURE=0.0
QUERY_TOP_P=1.0

# RAG 답변 생성은 celery-llm-rag-worker와 llm-parser를 사용합니다.
# 미설정 시 TEXT2SQL_* 설정을 상속합니다.
RAG_WORKER_CONCURRENCY=1
RAG_LLM_URL=http://llm-parser:8080
RAG_LLM_MODEL=google/gemma-4-E4B-it
RAG_MAX_TOKENS=2048
RAG_REQUEST_TIMEOUT=300
RAG_SEARCH_TOP_K=3
RAG_RETRIEVAL_THRESHOLD=0.25
RAG_EVIDENCE_LIMIT=3
RAG_CONTEXT_MAX_CHARS=2000
RAG_EVIDENCE_TEXT_MAX_CHARS=350
RAG_TEMPERATURE=0.2
RAG_TOP_P=0.9
